{
	"name": "moddable-http-server",
	"version": "0.0.1",
	"license": "MIT",
	"scripts": {
		"format": "biome format --write .",
		"lint": "biome lint --write .",
		"start": "mcconfig -d -m examples/basic/manifest.json",
		"test:http": "sh scripts/run-hurl-tests.sh",
		"test": "npm run start & sleep 3 & npm run test:http",
		"perf:get": "sh perf/get.sh",
		"perf": "npm run start & sleep 3 & npmr run perf:get"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@moddable/typings": "7.1.0"
	}
}
